# ===== OS / System Files =====
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
.directory

# ===== BACKEND (Django / Python) =====

# Virtual Environment
Backend/venv/
Backend/ENV/
Backend/env/
Backend/.venv/

# Python cache
Backend/__pycache__/
Backend/*.py[cod]
Backend/*$py.class
Backend/*.so
Backend/.Python

# Distribution / Packaging
Backend/build/
Backend/develop-eggs/
Backend/dist/
Backend/downloads/
Backend/eggs/
Backend/*.egg-info/
Backend/*.egg
Backend/MANIFEST

# Django
Backend/db.sqlite3
Backend/db.sqlite3-journal
Backend/media/
Backend/staticfiles/
Backend/static/
Backend/local_settings.py

# Django migrations (if temp)
# Backend/*/migrations/__pycache__/

# Testing
Backend/.pytest_cache/
Backend/.coverage
Backend/htmlcov/
Backend/coverage.xml
Backend/.tox/

# Celery / Beat
Backend/celerybeat-schedule
Backend/dump.rdb

# IDE / Editor
Backend/.vscode/
Backend/.idea/
Backend/*.sublime-project
Backend/*.sublime-workspace
Backend/*.swp
Backend/*.swo
Backend/*~

# Environment variables
Backend/.env
Backend/.env.local
Backend/.env.*.local

# Logs
Backend/*.log
Backend/logs/

# ===== FRONTEND (React / Vite / Node) =====

# Dependencies
Frontend/node_modules/
Frontend/.pnp
Frontend/.pnp.js

# Production / Build
Frontend/dist/
Frontend/build/
Frontend/.vite/
Frontend/.cache/

# Misc
Frontend/.DS_Store
Frontend/npm-debug.log*
Frontend/yarn-debug.log*
Frontend/yarn-error.log*
Frontend/pnpm-debug.log*
Frontend/lerna-debug.log*

# Environment variables
Frontend/.env
Frontend/.env.local
Frontend/.env.*.local
Frontend/.env.production.local

# IDE / Editor
Frontend/.vscode/
Frontend/.idea/
Frontend/*.sublime-project
Frontend/*.sublime-workspace
Frontend/*.swp
Frontend/*.swo
Frontend/*~

# Optional npm / yarn cache
# Frontend/package-lock.json
# Frontend/yarn.lock

# Temporary files
Frontend/.tmp
Frontend/*.temp

